# Cache
IV_CACHE_MAX_MB=1 #4096
IV_CACHE_MIN_KEEP_FILES=10 #1000
# USGS_API_KEY=

# Auth
# Optional: used only when the default Admin account is created for the first time.
AUTH_ADMIN_INITIAL_PASSWORD=
# Preferred for admin_reset.py. Keep this out of version control.
AUTH_ADMIN_RESET_PASSWORD=
SESSION_TIMEOUT_MINUTES=60

# Playground
# Fraction of the generated analysis shown in Playground mode.
PLAYGROUND_REPORT_TRUNCATION_RATIO=0.60

# Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_TIMEOUT_S=60

# OpenAI
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com

# Official station-context enrichment (USGS / Census / NWS)
STATION_CONTEXT_ENRICHMENT_ENABLED=1
STATION_CONTEXT_TIMEOUT_S=15
STATION_CONTEXT_CACHE_DAYS=14
