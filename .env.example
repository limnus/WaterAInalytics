# Cache
IV_CACHE_MAX_MB=1 #4096
IV_CACHE_MIN_KEEP_FILES=10 #1000
# USGS_API_KEY=

# Auth
# Optional: used only when the default Admin account is created for the first time.
AUTH_ADMIN_INITIAL_PASSWORD=
# Preferred for admin_reset.py. Keep this out of version control.
AUTH_ADMIN_RESET_PASSWORD=
SESSION_TIMEOUT_MINUTES=120

# Playground
# Fraction of the generated analysis shown in Playground mode.
PLAYGROUND_REPORT_TRUNCATION_RATIO=0.40

# Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_TIMEOUT_S=120

# OpenAI
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com

# Official station-context enrichment (USGS / Census / NWS)
STATION_CONTEXT_ENRICHMENT_ENABLED=1
STATION_CONTEXT_TIMEOUT_S=15
STATION_CONTEXT_CACHE_DAYS=14

# Agentic execution observability
AGENTIC_EXECUTION_LOG_ENABLED=1
AGENTIC_STAGE_SLOW_THRESHOLD_MS=8000

# Article / reproducible demo profile
# The main paper preset uses Flow (00060). Supplementary presets (for example Turbidity) are exposed in the UI
# without requiring manual .env edits when article mode is enabled.
ARTICLE_DEMO_ENABLED=1
ARTICLE_DEMO_NAME=Paper demo
ARTICLE_DEMO_STATION_IDS=USGS-05586100,USGS-07010000,USGS-07374525
ARTICLE_DEMO_STATION_LABELS=Station 1,Station 2,Station 3
ARTICLE_DEMO_PARAMETER_CODE=00060
ARTICLE_DEMO_HISTORY_DAYS=7
ARTICLE_DEMO_HORIZON_H=24
ARTICLE_DEMO_MODEL_KEY=ridge
