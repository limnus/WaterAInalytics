# WaterAInalytics - example environment configuration
# Copy this file to `.env` and fill secrets locally.
# Do not commit `.env`.

# -----------------------------------------------------------------------------
# Cache
# -----------------------------------------------------------------------------
# Maximum size of the IV cache in MB.
IV_CACHE_MAX_MB=1

# Minimum number of newest cache files to keep even when pruning by size.
IV_CACHE_MIN_KEEP_FILES=10

# Optional USGS API key if/when required by your local workflow.
# USGS_API_KEY=

# -----------------------------------------------------------------------------
# Authentication
# -----------------------------------------------------------------------------
# Used only when the default Admin account is created for the first time.
AUTH_ADMIN_INITIAL_PASSWORD=

# Preferred secret for admin password reset flows. Keep this out of version control.
AUTH_ADMIN_RESET_PASSWORD=

# Session timeout for authenticated users, in minutes.
SESSION_TIMEOUT_MINUTES=120

# -----------------------------------------------------------------------------
# Playground
# -----------------------------------------------------------------------------
# Fraction of the generated analysis shown in Playground mode.
# Example: 0.40 = 40% of the full report is shown.
PLAYGROUND_REPORT_TRUNCATION_RATIO=0.40

# -----------------------------------------------------------------------------
# Ollama (local)
# -----------------------------------------------------------------------------
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_TIMEOUT_S=120

# -----------------------------------------------------------------------------
# OpenAI
# -----------------------------------------------------------------------------
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com

# -----------------------------------------------------------------------------
# Official station-context enrichment (USGS / Census / NWS)
# -----------------------------------------------------------------------------
# Enable official geographic / contextual enrichment for agentic analysis.
STATION_CONTEXT_ENRICHMENT_ENABLED=1

# Timeout per external context request, in seconds.
STATION_CONTEXT_TIMEOUT_S=15

# Local cache lifetime for station-context enrichment, in days.
STATION_CONTEXT_CACHE_DAYS=14

# -----------------------------------------------------------------------------
# Agentic analysis observability
# -----------------------------------------------------------------------------
# Write lightweight execution telemetry logs for troubleshooting.
AGENTIC_EXECUTION_LOG_ENABLED=1

# Mark stages slower than this threshold (in milliseconds) as warnings.
AGENTIC_STAGE_SLOW_THRESHOLD_MS=8000
